# =============================================================================
# Client-side (bundled into app & web build) — prefixed EXPO_PUBLIC_
# =============================================================================
# These values are shipped to every client. Never put service-role keys or
# Stripe secret keys here.

# Supabase (project dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Places API — create in Google Cloud Console, restrict by:
#   - iOS: bundle ID `com.rewardsoptimizer.app`
#   - Android: package + SHA-1 fingerprint
#   - Web: HTTP referrer `https://<your-vercel-domain>/*`
#   - API restriction: Places API only
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Optional: Sentry DSN for error tracking. Leave blank to disable.
EXPO_PUBLIC_SENTRY_DSN=

# =============================================================================
# Supabase Edge Functions — set via `supabase secrets set KEY=value`
# =============================================================================
# These are NEVER bundled into the client. They only live in the function
# runtime. Do not prefix with EXPO_PUBLIC_.

# Supabase service role key — used by Edge Functions for privileged DB writes.
# Found at: Supabase dashboard → Settings → API → service_role (KEEP SECRET).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe price IDs — one per tier/interval combination.
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_MAX_MONTHLY=price_xxx
STRIPE_PRICE_MAX_ANNUAL=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx

# Public app URL — used for Stripe checkout success/cancel redirects.
APP_URL=https://rewardly.ca

# AI providers — set at least one. `AI_PROVIDER` picks which the sage-chat
# function prefers when both are set.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# =============================================================================
# Notes
# =============================================================================
# Never commit the actual `.env` / `.env.production` / `.env.development` file.
# Use `supabase secrets set` to push non-public values to Edge Functions.
# Use `vercel env add` to push non-public values to the Vercel deployment.
